# Supabase Configuration
# Get these from: https://app.supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Magic Link Redirect URL (for Authentication)
# For local Docker development, use: http://localhost:4173
# Make sure this URL is registered in Supabase Auth → URL Configuration
VITE_MAGIC_LINK_REDIRECT_URL=http://localhost:4173

# Development-only: Auth Bypass for local development
# Set to 'true' to login without Magic Link emails
# Only works when: import.meta.env.DEV === true (never in production)
# Usage: Set VITE_AUTH_BYPASS=true in frontend/.env.local
VITE_AUTH_BYPASS=false
