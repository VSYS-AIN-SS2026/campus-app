# Kopiere diese Datei nach .env und fülle die Werte aus.
# .env wird von .gitignore ignoriert — niemals committen.
#
# Verwendung:
#   npm run lsf:import
#
# Voraussetzung: VPN-Verbindung ins HTWG-Netz aktiv.

# ── Pflichtfelder ──────────────────────────────────────────────

# Semester im Format SS<YYYY> oder WS<YYYY>/<YY>
LSF_SEMESTER=SS2026

# Studiengang-Kürzel
LSF_STUDY_PROGRAM=AIN

# Numerische Studiengang-Versions-ID aus dem LSF (ABSTGVNR)
# Zu finden in der stgPlanList-URL des jeweiligen Studiengangs
LSF_ABSTGVNR=

# Supabase-Zugangsdaten (lokale DB: http://127.0.0.1:54321)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth: eine der beiden Optionen ausfüllen ───────────────────

# Option A — Session-Cookie (einfacher für lokale Tests):
#   1. Browser öffnen, im HTWG-VPN ins LSF einloggen
#   2. DevTools → Network → beliebigen LSF-Request → Header "Cookie" kopieren
LSF_SESSION_COOKIE=

# Option B — Automatischer Login mit TOTP:
#   LSF_TOTP_SECRET ist der Base32-Secret aus der Authenticator-App-Einrichtung
LSF_USERNAME=
LSF_PASSWORD=
LSF_TOTP_SECRET=

# ── Optionale Testparameter ────────────────────────────────────

# Nur die ersten N Module scrapen (leer = alle)
# Nützlich für schnelle Smoke-Tests: LSF_LIMIT=3
LSF_LIMIT=

# Import erzwingen, auch wenn dieses Semester schon importiert wurde
LSF_FORCE=false

# Pause zwischen Modul-Requests in ms (Standard: 500)
LSF_THROTTLE_MS=500
